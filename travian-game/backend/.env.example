# Variáveis de Ambiente - Backend

NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://travian:travian123@localhost:5432/travian_game

# Frontend
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=seu_secret_supersecreto_aqui_mude_em_producao
JWT_EXPIRES_IN=7d

# WebSocket
WS_PORT=5001
WS_CORS_ORIGIN=http://localhost:3000

# Game
TICK_INTERVAL_MS=86400000  # 24 horas em ms (86400000 ms = 1 dia)
TICK_INTERVAL_DEV_MS=300000  # 5 minutos para testing

# Logging
LOG_LEVEL=debug

# Email (para futuro)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
