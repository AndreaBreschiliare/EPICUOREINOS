# Backend Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/travian_feudos

# Backend Node Environment
NODE_ENV=production
PORT=5000

# Backend JWT & Security
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_minimo_32_caracteres

# Backend CORS
CORS_ORIGIN=https://thiagorivero.com.br

# Frontend API
VITE_API_URL=https://api.thiagorivero.com.br

# Redis (optional, for sessions)
REDIS_URL=redis://localhost:6379

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-app
SMTP_FROM=noreply@thiagorivero.com.br

# Application Settings
APP_NAME=Travian Feudos UO
APP_VERSION=1.0.0
LOG_LEVEL=info

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_GAME_START=true
