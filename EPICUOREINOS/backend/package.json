{
  "name": "travian-game-backend",
  "version": "0.1.0",
  "description": "Backend API para jogo estratégico baseado em Travian",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "knex migrate:latest && node src/app.js",
    "test": "jest",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "db:seed": "knex seed:run",
    "lint": "eslint src/"
  },
  "keywords": [
    "travian",
    "strategy",
    "game",
    "web"
  ],
  "author": "TravianUO Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "knex": "^2.5.1",
    "node-schedule": "^2.1.1",
    "pg": "^8.10.0",
    "socket.io": "^4.6.1",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "socket.io-client": "^4.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
